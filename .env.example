# EntryVine Event Frontend — environment template. Copy to `.env` and fill in.
# Only VITE_-prefixed keys are exposed to the browser bundle. These are PUBLIC
# values by nature (shipped to every browser); all secrets live in the backend.

# Backend gRPC-Web base URL. Must match backend ASPNETCORE_URLS port.
VITE_BACKEND_URL=http://localhost:60262

# Dev portal default when no subdomain present: public | admin | staff | developer
VITE_PORTAL=public

# Dev-only tenant slug for *.localhost admin/staff login (no tenant subdomain
# locally). Override per-tab with ?tenant=<slug>. Must match a seeded tenant.
VITE_TENANT_SLUG=acme

# Google OAuth 2.0 Web client ID (public). Canonical copy: backend GOOGLE_CLIENT_ID.
VITE_GOOGLE_CLIENT_ID=

# Stripe publishable key (public). Canonical copy: backend STRIPE_PUBLISHABLE_KEY.
VITE_STRIPE_PUBLISHABLE_KEY=

